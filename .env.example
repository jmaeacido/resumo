APP_NAME=Resumo

# MySQL is used immediately. Laragon commonly uses root with an empty password.
DB_CONNECTION=mysql
DB_DATABASE=resumo
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=

# Free/local AI provider. Leave enabled; app falls back if Ollama is offline.
OLLAMA_ENABLED=true
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=90
